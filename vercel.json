{
  "redirects": [
    {
      "source": "/admin",
      "has": [{ "type": "host", "value": "newdarshanjewellery.com" }],
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/admin/:path*",
      "has": [{ "type": "host", "value": "newdarshanjewellery.com" }],
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/admin",
      "has": [{ "type": "host", "value": "www.newdarshanjewellery.com" }],
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/admin/:path*",
      "has": [{ "type": "host", "value": "www.newdarshanjewellery.com" }],
      "destination": "/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "admin.newdarshanjewellery.com" }],
      "destination": "/admin"
    },
    {
      "source": "/((?!assets/|images/|api/|favicon\\.svg|robots\\.txt|sitemap\\.xml|New-Darshan-Jewellery-Hero\\.png).*)",
      "destination": "/index.html"
    }
  ],
  
  "headers": [
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    },
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    }
  ]
}